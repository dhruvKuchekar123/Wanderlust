<% layout("layouts/boilerplate") %>

<style>
/* Fullscreen background breaking out of container */
.auth-wrapper {
  margin: -1.5rem calc(-50vw + 50%) -1.5rem;
  width: 100vw;
  min-height: calc(100vh - 76px);
  background: url('https://images.pexels.com/photos/1371360/pexels-photo-1371360.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1080&dpr=1') center/cover no-repeat;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}
.auth-wrapper::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4); /* Dark overlay */
}

/* Glassmorphic Compact Card */
.auth-glass-card {
  position: relative;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 20px;
  padding: 1.8rem;
  width: 100%;
  max-width: 380px; /* Compact width */
  box-shadow: 0 15px 40px rgba(0,0,0,0.3);
  animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
[data-bs-theme="dark"] .auth-glass-card {
  background: rgba(30, 30, 40, 0.85);
  color: white;
}
@keyframes popIn {
  0% { opacity: 0; transform: scale(0.95) translateY(15px); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

/* Compact Forms to fit without scroll */
.form-floating > .form-control {
  height: 3.2rem;
  min-height: 3.2rem;
  border-radius: 12px;
  padding-top: 1.2rem;
  padding-bottom: 0.2rem;
  font-size: 0.95rem;
}
.form-floating > label {
  padding: 0.6rem 1rem;
  font-size: 0.9rem;
}
.form-floating > .form-control:focus ~ label,
.form-floating > .form-control:not(:placeholder-shown) ~ label {
  transform: scale(.8) translateY(-.6rem) translateX(.15rem);
  color: #ff385c;
}
.form-control:focus {
  border-color: #ff385c;
  box-shadow: 0 0 0 3px rgba(255,56,92,0.15);
}
.invalid-feedback { font-size: 0.75rem; margin-top: 2px; }

.btn-compact {
  padding: 0.6rem;
  border-radius: 12px;
  font-size: 0.95rem;
  transition: transform 0.2s, box-shadow 0.2s;
}
.btn-compact:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 15px rgba(0,0,0,0.15);
}

.auth-icon-header {
  width: 45px; height: 45px;
  background: linear-gradient(135deg, #ff385c, #e61e4d);
  color: white;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 0.8rem;
  font-size: 1.3rem;
  box-shadow: 0 4px 15px rgba(255,56,92,0.4);
}
</style>

<div class="auth-wrapper">
  <div class="auth-glass-card">
    <div class="text-center mb-3">
      <div class="auth-icon-header"><i class="fa-solid fa-plane-departure"></i></div>
      <h4 class="fw-bold mb-0">Join Wanderlust</h4>
      <p class="text-muted small mb-0">Create your free account</p>
    </div>

    <form action="/signup" method="POST" class="needs-validation" novalidate>
      <div class="form-floating mb-2">
        <input type="text" class="form-control" id="username" name="username" placeholder="Username" required>
        <label for="username">Username</label>
      </div>

      <div class="form-floating mb-2">
        <input type="email" class="form-control" id="email" name="email" placeholder="Email" required pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$">
        <label for="email">Email address</label>
      </div>

      <div class="form-floating mb-3 position-relative">
        <input type="password" class="form-control pe-5" id="password" name="password" placeholder="Password" required minlength="6">
        <label for="password">Password</label>
        <span class="position-absolute" style="right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #a1a1a1;" onclick="togglePass('password', this)">
          <i class="fa-regular fa-eye"></i>
        </span>
      </div>

      <button type="submit" class="btn btn-danger w-100 btn-compact fw-bold mb-3" style="background: linear-gradient(135deg, #ff385c, #e61e4d); border: none;">
        Create Account
      </button>
    </form>

    <div class="d-flex align-items-center mb-3 opacity-50">
      <hr class="flex-grow-1 m-0">
      <span class="mx-2 text-muted text-uppercase fw-semibold" style="font-size: 0.75rem;">Or</span>
      <hr class="flex-grow-1 m-0">
    </div>

    <a href="/auth/google" class="btn btn-outline-dark w-100 btn-compact d-flex align-items-center justify-content-center fw-bold">
      <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" style="width: 18px; margin-right: 8px;">
      Continue with Google
    </a>

    <p class="text-center text-muted mt-3 mb-0" style="font-size: 0.85rem;">
      Already have an account? <a href="/login" class="text-danger fw-bold text-decoration-none">Log in</a>
    </p>
  </div>
</div>

<script>
function togglePass(id, el) {
  const input = document.getElementById(id);
  const icon = el.querySelector('i');
  if(input.type === 'password') {
    input.type = 'text';
    icon.className = 'fa-regular fa-eye-slash';
  } else {
    input.type = 'password';
    icon.className = 'fa-regular fa-eye';
  }
}
</script>