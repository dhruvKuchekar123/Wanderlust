<% layout("layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <h2 class="mb-3 text-center">Forgot Password</h2>
    <div class="card p-4 shadow-sm border-0 rounded-4">
      <form action="/forgot" method="POST" class="needs-validation" novalidate>
        <div class="mb-3">
          <label for="email" class="form-label">Email Address</label>
          <input 
            type="email" 
            class="form-control" 
            id="email" 
            name="email" 
            placeholder="Enter your email address" 
            required
          />
          <div class="invalid-feedback">
            Please enter a valid email address.
          </div>
        </div>
        <button class="btn btn-danger btn-lg w-100 mt-2 rounded-pill fw-bold" type="submit">Reset Password</button>
      </form>
    </div>
  </div>
</div>
