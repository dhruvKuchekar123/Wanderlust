<nav class="navbar navbar-expand-md sticky-top shadow-sm" id="mainNavbar">
  <div class="container-fluid px-3 px-md-4">

    <!-- Brand -->
    <a class="navbar-brand fw-bold text-danger d-flex align-items-center gap-2" href="/listings">
      <i class="fa-solid fa-hotel"></i>
      <span>Wanderlust</span>
    </a>

    <!-- Desktop nav links (hidden on mobile) -->
    <div class="d-none d-md-flex align-items-center gap-3 me-3">
      <a class="nav-link fw-medium" href="/listings">Explore</a>
      <% if(currUser) { %>
        <a class="nav-link fw-medium" href="/listings/new">Add Listing</a>
      <% } %>
    </div>

    <!-- Search bar (center) -->
    <form class="d-flex flex-grow-1 mx-0 mx-md-3" role="search" method="GET" action="/listings">
      <div class="input-group w-100">
        <input class="form-control search-input" type="search" placeholder="Search destinations..." aria-label="Search" name="q" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"/>
        <button class="btn btn-danger px-3" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i>
          <span class="d-none d-md-inline ms-2">Search</span>
        </button>
      </div>
    </form>

    <!-- Right side: theme toggle + user actions (desktop only) -->
    <div class="d-none d-md-flex align-items-center gap-2 ms-2">
      <button class="btn btn-sm btn-outline-secondary border-0 rounded-circle theme-btn" id="theme-toggle" aria-label="Toggle theme" title="Toggle Dark Mode">
        <i class="fa-solid fa-moon"></i>
      </button>
      <% if(!currUser) { %>
        <a class="btn btn-sm btn-outline-danger rounded-pill px-3" href="/signup">Sign up</a>
        <a class="btn btn-sm btn-danger rounded-pill px-3" href="/login">Log in</a>
      <% } else { %>
        <a class="btn btn-sm btn-outline-secondary rounded-pill px-3 d-flex align-items-center gap-1" href="/users/<%= currUser._id %>">
          <i class="fa-solid fa-circle-user"></i>
          <span><%= currUser.username %></span>
        </a>
        <a class="btn btn-sm btn-outline-danger rounded-pill px-3" href="/logout">Log out</a>
      <% } %>
    </div>

    <!-- Mobile: theme toggle only -->
    <button class="btn btn-sm btn-outline-secondary border-0 rounded-circle d-md-none ms-2 theme-btn" id="theme-toggle-mobile" aria-label="Toggle theme">
      <i class="fa-solid fa-moon"></i>
    </button>
  </div>
</nav>
