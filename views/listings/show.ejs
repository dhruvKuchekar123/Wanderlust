<% layout("layouts/boilerplate") %>
<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>"; // ✅ removed trailing space
  const coordinates = <%-JSON.stringify(listing.geometry.coordinates)%>; // ✅ correctly parse as array -->
</script>
  <div class="container py-5">    
    <div class="bg-white p-5 rounded-4 shadow-lg mx-auto" style="max-width: 700px;">
      <h2 class="mb-4 text-center text-uppercase fw-bold text-primary display-8">
      <%= listing.title %>
    </h2>
      <!-- Image -->
      <div class="mb-4 text-center">
        <img src="<%= listing.image.url %>" alt="listing_image" class="img-fluid rounded-4 shadow-sm" style="height: 320px; object-fit: cover;">
      </div>
      <!-- Owner -->
      <div class="mb-3 text-center text-muted">
        Owned by <i class="fa-solid fa-user me-1"></i>
        <em>
          <%= listing.owner && listing.owner.username ? listing.owner.username : "Unknown" %>
        </em>
      </div>
      <!-- Description -->
      <div class="mb-3">
        <label class="form-label fw-semibold text-dark">Description</label>
        <p class="form-control-plaintext fs-6 text-muted"><%= listing.description %></p>
      </div>
      <!-- Price -->
      <div class="mb-3">
        <label class="form-label fw-semibold text-dark">Price</label>
        <p class="form-control-plaintext text-success fw-bold fs-5">₹<%= listing.price.toLocaleString("en-IN") %> / night</p>
      </div>
      <!-- Location -->
      <div class="mb-4">
        <label class="form-label fw-semibold text-dark">Location</label>
        <p class="form-control-plaintext text-muted"><%= listing.location %>, <%= listing.country %></p>
      </div>
      <!-- Action Buttons (Edit/Delete only for owner) -->
      <% if (currUser && listing.owner && listing.owner._id.toString() === currUser._id.toString()) { %>
        <div class="d-flex justify-content-between align-items-center mb-4">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning px-4">
            <i class="fa-solid fa-pen-to-square me-1"></i> Edit
          </a>
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE"
                onsubmit="return confirm('Are you sure you want to delete this listing?');">
            <button type="submit" class="btn btn-danger px-4">
              <i class="fa-solid fa-trash-can me-1"></i> Delete
            </button>
          </form>
        </div>
      <% } %>

      <hr class="mb-5">
      <!-- Review Form -->
      <% if (currUser) { %>
        <div class="mt-4">
          <h5 class="fw-bold mb-4 text-center text-primary">Leave a Review</h5>

          <form action="/listings/<%= listing._id %>/reviews" method="POST" class="p-4 rounded-4 bg-light border shadow-sm">
            <!-- Rating -->
            <div class="mb-4">
              <label for="rating" class="form-label fw-semibold text-dark">
                Rating (1 to 5): <span id="ratingValue" class="text-primary fw-bold">3</span>
              </label>
              <input 
                type="range" 
                min="1" 
                max="5" 
                value="3" 
                class="form-range" 
                name="review[rating]" 
                id="rating"
                oninput="document.getElementById('ratingValue').textContent = this.value"
                required
              />
            </div>

            <!-- Comment -->
            <div class="mb-4">
              <label for="comment" class="form-label fw-semibold text-dark">Comment</label>
              <textarea 
                class="form-control" 
                name="review[comment]" 
                id="comment" 
                rows="4"
                placeholder="Write your thoughts about this place..."
                required
              ></textarea>
            </div>

            <!-- Submit Button -->
            <div class="text-center">
              <button type="submit" class="btn btn-success px-5">
                <i class="fa-solid fa-paper-plane me-1"></i> Submit Review
              </button>
            </div>
          </form>
        </div>
      <% } %>
   <!-- Display All Reviews -->
      <% if (listing.reviews.length > 0) { %>
        <hr class="my-5">
        <h5 class="fw-bold mb-4 text-center text-secondary">What Others Are Saying</h5>

        <div class="row g-4">
          <% listing.reviews.forEach((review) => { %>
            <div class="col-md-6">
              <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body d-flex flex-column justify-content-between">
                  <h6 class="card-subtitle mb-2 text-muted">
                    <i class="fa-solid fa-user me-1"></i>
                    <%= review.author && review.author.username ? review.author.username : "Anonymous" %>
                  </h6>

                  <!-- Rating & Date -->
                  <div class="d-flex justify-content-between mb-2 align-items-center">
                    <div>
                      <% for (let i = 1; i <= 5; i++) { %>
                        <i class="fa-star <%= i <= review.rating ? 'fas text-warning' : 'far text-muted' %>"></i>
                      <% } %>
                      <span class="fw-semibold text-success ms-1"><%= review.rating %> / 5</span>
                    </div>
                    <small class="text-muted">
                      <%= review.createdAt ? new Date(review.createdAt).toLocaleDateString("en-IN", { day: 'numeric', month: 'short', year: 'numeric' }) : "Just now" %>
                    </small>
                  </div>

                  <!-- Comment -->
                  <% if (review.comment && review.comment.trim().length > 0) { %>
                    <p class="card-text text-dark">
                      <i class="fa-solid fa-quote-left me-1 text-secondary"></i>
                      <%= review.comment %>
                    </p>
                  <% } else { %>
                    <p class="text-muted fst-italic">No comment provided.</p>
                  <% } %>

                  <!-- Delete Review -->
                  <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this review?');">
                    <button class="btn btn-sm btn-outline-danger w-100 mt-3">
                      <i class="fa-solid fa-trash-can me-1"></i> Delete
                    </button>
                  </form>

                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-muted text-center mt-4">No reviews yet. Be the first to leave one!</p>
      <% } %>

    </div>
    <div class="bg-white p-5 rounded-4 shadow-lg mx-auto" style="max-width: 700px;">
       <h3>Where You'll be</h3>
       <div id="map" style="height: 400px;"></div>
    </div>
  </div>
 <script src="/js/map.js"></script>

