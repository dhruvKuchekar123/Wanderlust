<body class="d-flex flex-column min-vh-100">

  <!-- Navbar -->
  <%- include("../includes/navbar.ejs") %>

  <!-- Flash Messages -->
  <%- include("../includes/flash.ejs") %>

  <!-- Main Page Content -->
